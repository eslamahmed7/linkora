{
  "name": "linkora",
  "version": "1.0.0",
  "type": "module",
  "description": "Premium link page creator with dynamic QR codes",
  "author": "Linkora Team",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:client\" \"pnpm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "nodemon --exec tsx server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "preview": "vite preview",
    "start": "tsx server/index.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "framer-motion": "^12.42.2",
    "html-to-image": "^1.11.13",
    "i18next": "^26.3.6",
    "jimp": "^1.6.1",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.24.0",
    "node-cache": "^5.1.2",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-easy-crop": "^6.2.2",
    "react-i18next": "^17.0.9",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1",
    "sharp": "^0.35.3",
    "swr": "^2.4.2",
    "uuid": "^14.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.2.2",
    "vite": "^4.5.14"
  }
}
